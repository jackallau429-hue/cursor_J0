# Volume bar: proportional red/green INSIDE each histogram column (Thinkorswim ThinkScript)
# Studies → Create → paste → Save → add to LOWER subgraph (declare lower)
#
# Why not AddCloud: AddCloud fills BETWEEN bars, so it looks like a continuous "mountain".
# This version uses two HISTOGRAM plots per bar:
#   1) Plot full height in GREEN (buy+sell total)
#   2) Plot SELL portion in RED on top — red covers the bottom of the column, leaving GREEN visible
#      only from sellVol..volume (top buy-share slice). Result: discrete vertical bars.
#
# IMPORTANT: CLR proxy, NOT tape / aggressor truth:
#   buyShare  = (close - low) / (high - low)
#   sellShare = (high - close) / (high - low)
# Flat bars: mild bias from close vs open. Hide built-in volume to avoid double stacks.

declare lower;

input showFootnote = yes;

def buyShare = if high != low then (close - low) / (high - low) else if close > open then 0.55 else if close < open then 0.45 else 0.5;
def buyVol = volume * buyShare;
def sellVol = volume - buyVol;

# Background column (full height) = green "buy+remaining" paint; must be declared FIRST.
plot VolGreen = if volume > 0 then volume else Double.NaN;
VolGreen.SetPaintingStrategy(PaintingStrategy.HISTOGRAM);
VolGreen.SetDefaultColor(Color.DARK_GREEN);
VolGreen.SetLineWeight(5);

# Foreground column (bottom overlay) = red sell estimate; declared SECOND so it draws on top.
plot VolRed = if volume > 0 then sellVol else Double.NaN;
VolRed.SetPaintingStrategy(PaintingStrategy.HISTOGRAM);
VolRed.SetDefaultColor(Color.DARK_RED);
VolRed.SetLineWeight(5);

AddLabel(showFootnote, "Vol: CLR stacked histogram (not tape)", Color.DARK_GRAY);
