# Volume bar: proportional red/green IN ONE COLUMN (Thinkorswim ThinkScript)
# Studies → Create → paste → Save → add to LOWER subgraph (declare lower)
#
# Visual: each bar is a single vertical column; bottom portion is RED (sellShare),
# top portion is GREEN (buyShare), heights match the split (e.g. 80% red / 20% green).
#
# IMPORTANT: This is a CLR proxy, NOT tape / aggressor truth:
#   buyShare  = (close - low) / (high - low)
#   sellShare = (high - close) / (high - low)
# Flat bars: mild bias from close vs open. Hide built-in volume to avoid double stacks.

declare lower;

input showFootnote = yes;

def safeTick = if !IsNaN(TickSize()) and TickSize() > 0 then TickSize() else 0.01;
def buyShare = if high != low then (close - low) / (high - low) else if close > open then 0.55 else if close < open then 0.45 else 0.5;
def buyVol = volume * buyShare;
def sellVol = volume - buyVol;

# Split boundary: avoid degenerate clouds when one side is ~0
def splitAdj =
    if volume <= 0 then Double.NaN
    else if sellVol <= 0 then 0
    else if buyVol <= 0 then volume
    else sellVol;

plot VolBase = if volume > 0 then 0 else Double.NaN;
plot VolSplit = splitAdj;
plot VolTop = if volume > 0 then volume else Double.NaN;

VolBase.SetHiding(yes);
VolSplit.SetHiding(yes);
VolTop.SetHiding(yes);

AddCloud(VolBase, VolSplit, Color.DARK_RED, Color.DARK_RED);
AddCloud(VolSplit, VolTop, Color.DARK_GREEN, Color.DARK_GREEN);

AddLabel(showFootnote, "Vol: CLR in-bar split (not tape)", Color.DARK_GRAY);
