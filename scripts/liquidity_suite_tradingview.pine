// © Liquidity + AVWAP + VP suite — paste into TradingView Pine Editor as a new indicator.

//@version=5
indicator("Liquidity sweep · Anchored VWAP · Volume profile · Δ proxy", shorttitle="Liq+AVWAP+VP", overlay = true, max_labels_count = 500, max_lines_count = 500, max_boxes_count = 500)

// ── Inputs ─────────────────────────────────────────────────────────────
grpSweep = "Liquidity sweep (pivot liquidity)"
pivotLeft  = input.int(3, "Pivot left bars", minval = 1, group = grpSweep)
pivotRight = input.int(3, "Pivot right bars", minval = 1, group = grpSweep)
showSweepLabels = input.bool(true, "Show sweep labels", group = grpSweep)

grpVwap = "Anchored VWAP"
anchorTime = input.time(timestamp("1 Jan 2024 00:00 +0000"), "Anchor date/time (chart TZ)", group = grpVwap)
useHlc3 = input.bool(true, "Typical price = HLC3 (else OHLC4)", group = grpVwap)

grpVp = "Volume profile (fixed lookback)"
vpLookback = input.int(120, "VP lookback bars", minval = 20, maxval = 5000, group = grpVp)
vpBins = input.int(48, "Price bins", minval = 12, maxval = 200, group = grpVp)
showPoc = input.bool(true, "Plot POC line", group = grpVp)
showVa = input.bool(true, "Plot value area (approx. 70%)", group = grpVp)
vpLineWidth = input.int(2, "VP line width", minval = 1, maxval = 5, group = grpVp)

grpOf = "Order-flow proxy (retail limitation)"
showDeltaLabel = input.bool(true, "Show session cum. Δ proxy on last bar", group = grpOf)
// Rough proxy only — not exchange order flow / real delta.

// ── Typical price for VWAP / VP ───────────────────────────────────────
typ = useHlc3 ? hlc3 : ohlc4

// ── Anchored VWAP ─────────────────────────────────────────────────────
var float sumPV = na
var float sumV = na
pastAnchor = time >= anchorTime
// First bar on/after anchor: crossing, or chart starts already past anchor
firstPastBar = pastAnchor and (barstate.isfirst or time[1] < anchorTime)

if pastAnchor
    if firstPastBar
        sumPV := typ * volume
        sumV := volume
    else
        sumPV := sumPV[1] + typ * volume
        sumV := sumV[1] + volume
else
    sumPV := na
    sumV := na

avwap = sumV != 0 and not na(sumPV) ? sumPV / sumV : na
plot(avwap, "Anchored VWAP", color = color.new(color.orange, 0), linewidth = 2)

// ── Pivot highs / lows (confirmed after right bars) ───────────────────
ph = ta.pivothigh(high, pivotLeft, pivotRight)
pl = ta.pivotlow(low, pivotLeft, pivotRight)

var float lastPH = na
var float lastPL = na
if not na(ph)
    lastPH := ph
if not na(pl)
    lastPL := pl

// Sweep: take liquidity beyond pivot then close back through pivot
bullSweep = not na(lastPL) and low < lastPL and close > lastPL and low[1] >= lastPL
bearSweep = not na(lastPH) and high > lastPH and close < lastPH and high[1] <= lastPH

plotshape(bullSweep and showSweepLabels, title = "Bull liquidity sweep", style = shape.triangleup, location = location.belowbar, size = size.tiny, color = color.new(color.teal, 0), text = "Liq↓")
plotshape(bearSweep and showSweepLabels, title = "Bear liquidity sweep", style = shape.triangledown, location = location.abovebar, size = size.tiny, color = color.new(color.red, 0), text = "Liq↑")

// ── Volume profile (last vpLookback bars, on last bar) ────────────────
var float poc = na
var float vah = na
var float val = na

if barstate.islast
    float hi = ta.highest(high, vpLookback)
    float lo = ta.lowest(low, vpLookback)
    float span = math.max(hi - lo, syminfo.mintick)
    float step = span / vpBins
    var int[] binVol = array.new_int(vpBins, 0)
    array.fill(binVol, 0)
    for i = 0 to vpLookback - 1
        float px = typ[i]
        int b = int(math.floor((px - lo) / step))
        b := math.max(0, math.min(vpBins - 1, b))
        array.set(binVol, b, array.get(binVol, b) + int(volume[i]))
    int maxV = 0
    int pocBin = 0
    int totalV = 0
    for b = 0 to vpBins - 1
        int v = array.get(binVol, b)
        totalV += v
        if v > maxV
            maxV := v
            pocBin := b
    poc := lo + (pocBin + 0.5) * step
    // ~70% volume around POC
    int target = int(math.round(totalV * 0.70))
    int acc = array.get(binVol, pocBin)
    int loB = pocBin
    int hiB = pocBin
    while acc < target and (loB > 0 or hiB < vpBins - 1)
        int vDown = loB > 0 ? array.get(binVol, loB - 1) : -1
        int vUp = hiB < vpBins - 1 ? array.get(binVol, hiB + 1) : -1
        if vUp >= vDown
            hiB += 1
            acc += math.max(vUp, 0)
        else
            loB -= 1
            acc += math.max(vDown, 0)
    val := lo + loB * step
    vah := lo + (hiB + 1) * step

plot(showPoc and barstate.islast ? poc : na, "VP POC", color = color.new(color.yellow, 0), linewidth = vpLineWidth, style = plot.style_linebr)
plot(showVa and barstate.islast ? vah : na, "VP VAH", color = color.new(color.gray, 40), linewidth = 1, style = plot.style_linebr)
plot(showVa and barstate.islast ? val : na, "VP VAL", color = color.new(color.gray, 40), linewidth = 1, style = plot.style_linebr)

// ── Session cumulative delta proxy (sign from candle direction) ─────────
isNewSess = ta.change(time("D")) != 0
var float sessDelta = 0.0
sessBarDelta = close > open ? volume : close < open ? -volume : 0.0
sessDelta := isNewSess ? sessBarDelta : sessDelta[1] + sessBarDelta

if showDeltaLabel and barstate.islast
    label.new(bar_index, high, "Δ proxy (session): " + str.tostring(sessDelta, "#.##"), style = label.style_label_lower_left, color = color.new(color.black, 85), textcolor = color.white, size = size.small)
